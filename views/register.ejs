<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daftar Akun - EzheGheler</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;800&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/auth.css">
    <script src="https://cdn.jsdelivr.net/particles.js/2.0.0/particles.min.js"></script>
</head>

<body>
    <div class="ambient-bg">
        <div id="particles-js" style="position: absolute; width: 100%; height: 100%; z-index: 1; opacity: 0.6;"></div>
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>

    </div>

    <div class="container">
        <!-- Left Side -->
        <div class="info-side">
            <div class="brand-logo"><i class="fa-solid fa-network-wired"></i> EzheGheler Platform</div>

            <div class="live-badge" id="pingBadge" style="transition: all 0.3s; cursor: default;">
                <div class="pulse-dot"></div> Node.js Server Aktif <span id="pingText" style="margin-left:5px; opacity:0.8; font-weight: 500;">(Memuat...)</span>
            </div>

            <h1>Advanced Socket<br>Programming</h1>
            <p class="lead">Implementasi arsitektur jaringan berbasis klien-server. Sistem ini menggabungkan integritas
                data dari protokol TCP dan kecepatan transmisi dari protokol UDP.</p>

            <div class="features">
                <div class="feature-item">
                    <div class="feature-icon"><i class="fa-solid fa-envelope-open-text"></i></div>
                    <div class="feature-text">
                        <h4>Real-time Email Verification</h4>
                        <p>Autentikasi terintegrasi langsung dengan SMTP (Nodemailer) yang mengirim log email seketika
                            saat sesi dimulai.</p>
                    </div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon"><i class="fa-solid fa-file-export"></i></div>
                    <div class="feature-text">
                        <h4>TCP File Transfer</h4>
                        <p>Penyaluran berkas biner secara andal (reliable) melintasi socket TCP khusus (Port 3001) antar
                            jaringan Klien-Server.</p>
                    </div>
                </div>
                <div class="feature-item">
                    <div class="feature-icon"
                        style="color: var(--secondary); background: rgba(236, 72, 153, 0.1); border-color: rgba(236, 72, 153, 0.2);">
                        <i class="fa-solid fa-satellite-dish"></i></div>
                    <div class="feature-text">
                        <h4>UDP Media Broadcasting</h4>
                        <p>Distribusi potongan aliran media video langsung dengan kecepatan maksimal menggunakan soket
                            datagram (Port 4000).</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side -->
        <div class="login-side">
            <div class="login-card">
                <h2>Buat Akun Baru</h2>
                <p>Daftarkan email Anda. Kode verifikasi akan dikirim ke inbox email tersebut.</p>

                <% if (typeof success !=='undefined' && success) { %>
                    <div class="error-msg" style="background: rgba(16, 185, 129, 0.1); color: #10b981; border-color: rgba(16, 185, 129, 0.2);">
                        <%= success %>
                    </div>
                <% } %>
                <% if (typeof error !=='undefined' && error) { %>
                    <div class="error-msg">
                        <%= error %>
                    </div>
                <% } %>

                        <form action="/register" method="POST">
                            <div class="input-group">
                                <label for="email">Alamat Email</label>
                                <div class="input-wrapper">
                                    <input type="email" id="email" name="email" required placeholder="nama@domain.com">
                                    <i class="fa-solid fa-envelope"></i>
                                </div>
                            </div>

                            <div class="input-group">
                                <label for="password">Buat Kata Sandi</label>
                                <div class="input-wrapper">
                                    <input type="password" id="password" name="password" required placeholder="Min. 6 karakter">
                                    <i class="fa-solid fa-lock"></i>
                                    <button type="button" class="toggle-password" onclick="togglePassword()">
                                        <i class="fa-solid fa-eye" id="eyeIcon"></i>
                                    </button>
                                </div>
                            </div>

                            <button type="submit">
                                Daftar & Kirim Kode Verifikasi <i class="fa-solid fa-paper-plane"></i>
                            </button>
                            <p style="text-align: center; margin-top: 20px; color: var(--text-muted); font-size: 14px;">
                                Sudah punya akun? <a href="/" style="color: var(--primary); text-decoration: none; font-weight: 600;">Masuk di sini</a>
                            </p>
                        </form>
            </div>
        </div>
    </div>
</body>

<script src="/js/auth.js"></script>
<script>
    // Inisialisasi Animasi Jaringan (Particles.js)
    particlesJS("particles-js", {
        "particles": {
            "number": { "value": 60, "density": { "enable": true, "value_area": 800 } },
            "color": { "value": "#4f46e5" },
            "shape": { "type": "circle" },
            "opacity": { "value": 0.5, "random": false },
            "size": { "value": 3, "random": true },
            "line_linked": { "enable": true, "distance": 150, "color": "#ec4899", "opacity": 0.4, "width": 1 },
            "move": { "enable": true, "speed": 2, "direction": "none", "random": false, "straight": false, "out_mode": "out", "bounce": false }
        },
        "interactivity": {
            "detect_on": "canvas",
            "events": { "onhover": { "enable": true, "mode": "grab" }, "onclick": { "enable": true, "mode": "push" }, "resize": true },
            "modes": { "grab": { "distance": 140, "line_linked": { "opacity": 1 } }, "push": { "particles_nb": 4 } }
        },
        "retina_detect": true
    });

    // Fitur Ping Latency Real-time
    function measurePing() {
        const start = Date.now();
        fetch('/ping')
            .then(res => res.json())
            .then(() => {
                const latency = Date.now() - start;
                const pingText = document.getElementById('pingText');
                pingText.innerText = `(Ping: ${latency}ms)`;
                
                // Ubah warna dot berdasarkan kualitas jaringan
                const dot = document.querySelector('.pulse-dot');
                if (latency < 100) {
                    dot.style.background = '#34d399'; // Hijau cepat
                    dot.style.boxShadow = '0 0 10px #34d399';
                } else if (latency < 300) {
                    dot.style.background = '#f59e0b'; // Oranye sedang
                    dot.style.boxShadow = '0 0 10px #f59e0b';
                } else {
                    dot.style.background = '#ef4444'; // Merah lambat
                    dot.style.boxShadow = '0 0 10px #ef4444';
                }
            })
            .catch(() => {
                document.getElementById('pingText').innerText = "(Server Offline)";
                document.querySelector('.pulse-dot').style.background = '#ef4444';
            });
    }

    // Cek ping setiap 3 detik
    measurePing();
    setInterval(measurePing, 3000);
</script>

</html>