<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - EzheGheler</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-main: #050505;
            --bg-navbar: rgba(15, 15, 20, 0.85);
            --panel-bg: rgba(20, 20, 25, 0.6);
            --border-color: rgba(255, 255, 255, 0.08);
            --text-light: #ffffff;
            --text-muted: #a1a1aa;
            --primary: #4338ca;
            --primary-glow: rgba(67, 56, 202, 0.5);
            --secondary: #ec4899;
            --success: #10b981;
            --warning: #f59e0b;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--bg-main);
            background-image: radial-gradient(circle at 15% 50%, rgba(67, 56, 202, 0.15), transparent 25%),
                radial-gradient(circle at 85% 30%, rgba(236, 72, 153, 0.15), transparent 25%);
            color: var(--text-light);
            margin: 0;
            display: flex;
            flex-direction: column;
            height: 100vh;
            overflow: hidden;
        }

        /* Top Navbar Styles */
        .navbar {
            width: 100%;
            height: 75px;
            background: var(--bg-navbar);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 40px;
            box-sizing: border-box;
            z-index: 10;
        }

        .navbar-left {
            display: flex;
            align-items: center;
            gap: 40px;
        }

        .brand {
            font-size: 24px;
            font-weight: 800;
            color: white;
            display: flex;
            align-items: center;
            gap: 10px;
            letter-spacing: -0.5px;
        }

        .brand-icon {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            font-size: 26px;
        }

        .nav-menu {
            display: flex;
            gap: 10px;
        }

        .nav-item {
            padding: 10px 18px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 10px;
            color: var(--text-muted);
            font-weight: 500;
            transition: all 0.3s ease;
            border-radius: 10px;
        }

        .nav-item:hover {
            background: rgba(255, 255, 255, 0.03);
            color: var(--text-light);
        }

        .nav-item.active {
            background: linear-gradient(180deg, transparent, rgba(67, 56, 202, 0.15));
            color: var(--primary);
            border-bottom: 3px solid var(--primary);
            border-radius: 10px 10px 0 0;
        }

        .navbar-right {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .user-email {
            font-size: 14px;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn-logout {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 8px 16px;
            border-radius: 8px;
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            color: #fca5a5;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .btn-logout:hover {
            background: rgba(239, 68, 68, 0.2);
            transform: translateY(-2px);
        }

        /* Main Content */
        .main-container {
            flex: 1;
            display: flex;
            justify-content: center;
            overflow-y: auto;
            padding: 40px 20px;
        }

        .main-content {
            width: 100%;
            max-width: 900px;
            position: relative;
        }

        .page {
            display: none;
            animation: fadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .page.active {
            display: block;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .header-title {
            font-size: 36px;
            font-weight: 800;
            margin-top: 0;
            margin-bottom: 8px;
            letter-spacing: -1px;
        }

        .header-desc {
            color: var(--text-muted);
            font-size: 16px;
            margin-bottom: 40px;
        }

        .card {
            background: var(--panel-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            padding: 35px;
            margin-bottom: 30px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        }

        /* Upload Area */
        .file-drop-area {
            border: 2px dashed rgba(67, 56, 202, 0.4);
            border-radius: 16px;
            padding: 50px 20px;
            text-align: center;
            background: rgba(0, 0, 0, 0.3);
            margin-bottom: 25px;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .file-drop-area:hover {
            border-color: var(--primary);
            background: rgba(67, 56, 202, 0.05);
        }

        .file-drop-area i {
            font-size: 56px;
            color: var(--primary);
            margin-bottom: 20px;
            filter: drop-shadow(0 0 10px var(--primary-glow));
        }

        .file-input {
            margin-top: 20px;
            color: var(--text-light);
            font-family: 'Outfit';
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            border: none;
            padding: 14px 28px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 16px;
            font-family: 'Outfit';
            cursor: pointer;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 10px 20px rgba(67, 56, 202, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(67, 56, 202, 0.5);
        }

        .alert {
            padding: 16px 24px;
            border-radius: 12px;
            margin-bottom: 30px;
            display: none;
            align-items: center;
            gap: 15px;
            font-weight: 500;
            animation: slideDown 0.5s ease;
        }

        @keyframes slideDown {
            from {
                transform: translateY(-20px);
                opacity: 0;
            }

            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .alert.success {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
            border: 1px solid rgba(16, 185, 129, 0.2);
            display: flex;
        }

        /* UDP Logs */
        .udp-logs {
            background: rgba(0, 0, 0, 0.6);
            padding: 20px;
            border-radius: 12px;
            font-family: 'Consolas', monospace;
            color: #34d399;
            height: 150px;
            overflow-y: auto;
            font-size: 13px;
            border: 1px solid var(--border-color);
            box-shadow: inset 0 5px 15px rgba(0, 0, 0, 0.5);
        }

        .udp-logs::-webkit-scrollbar {
            width: 8px;
        }

        .udp-logs::-webkit-scrollbar-track {
            background: rgba(0, 0, 0, 0.3);
        }

        .udp-logs::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 4px;
        }

        /* ================= VIDEO UI ================= */
        .live-container {
            position: relative;
            background: #000;
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid var(--border-color);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6);
            width: 100%;
        }

        .video-wrapper {
            position: relative;
            background: #000;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        video {
            width: 100%;
            max-height: 550px;
            object-fit: contain;
            outline: none;
        }

        .live-overlay {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            padding: 20px;
            display: flex;
            justify-content: space-between;
            pointer-events: none;
            z-index: 2;
            background: linear-gradient(to bottom, rgba(0, 0, 0, 0.8), transparent);
        }

        .live-badge {
            background: #ef4444;
            color: white;
            padding: 5px 12px;
            border-radius: 6px;
            font-weight: 700;
            font-size: 13px;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            gap: 6px;
            animation: blink 2s infinite;
        }

        @keyframes blink {

            0%,
            100% {
                opacity: 1;
            }

            50% {
                opacity: 0.6;
            }
        }

        /* ================= HOME DASHBOARD ================= */
        .grid-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-top: 30px;
        }

        .quick-card {
            background: rgba(20, 20, 25, 0.4);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 25px;
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
        }

        .quick-card:hover {
            transform: translateY(-5px);
            border-color: rgba(67, 56, 202, 0.5);
            background: rgba(20, 20, 25, 0.8);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }

        .quick-icon {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            background: rgba(67, 56, 202, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: var(--primary);
            margin-bottom: 20px;
        }

        .quick-card h3 {
            margin: 0 0 10px 0;
            font-size: 18px;
            color: #fff;
        }

        .quick-card p {
            color: var(--text-muted);
            font-size: 14px;
            margin: 0 0 20px 0;
            line-height: 1.6;
            flex: 1;
        }

        .btn-outline {
            background: transparent;
            border: 1px solid var(--border-color);
            color: white;
            padding: 10px 20px;
            border-radius: 8px;
            font-family: 'Outfit';
            cursor: pointer;
            transition: 0.3s;
            font-weight: 500;
            font-size: 14px;
        }

        .btn-outline:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: white;
        }

        .stat-banner {
            background: linear-gradient(135deg, rgba(67, 56, 202, 0.2), rgba(236, 72, 153, 0.1));
            border: 1px solid rgba(67, 56, 202, 0.3);
            border-radius: 20px;
            padding: 30px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .stat-item {
            text-align: center;
        }

        .stat-val {
            font-size: 28px;
            font-weight: 800;
            color: #fff;
            margin-bottom: 5px;
        }

        .stat-label {
            font-size: 13px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
        }
    </style>
</head>

<body>

    <!-- Navbar Top -->
    <div class="navbar">
        <div class="navbar-left">
            <div class="brand"><i class="fa-solid fa-bolt brand-icon"></i> EzheGheler</div>
            <div class="nav-menu">
                <div class="nav-item active" onclick="switchPage('home', this)"><i class="fa-solid fa-house"></i>
                    Beranda</div>
                <div class="nav-item" onclick="switchPage('upload', this)"><i class="fa-solid fa-cloud-arrow-up"></i>
                    TCP Upload</div>
                <div class="nav-item" onclick="switchPage('stream', this)"><i class="fa-solid fa-satellite-dish"></i>
                    UDP Streaming</div>
            </div>
        </div>
        <div class="navbar-right">
            <div class="user-email"><i class="fa-solid fa-circle-user"></i>
                <%= email %>
            </div>
            <a href="/" class="btn-logout"><i class="fa-solid fa-power-off"></i> Logout</a>
        </div>
    </div>

    <!-- Main Content Area -->
    <div class="main-container">
        <div class="main-content">
            <% if (typeof uploadStatus !=='undefined' && uploadStatus) { %>
                <script>window.onload = () => switchPage('upload', document.querySelectorAll('.nav-item')[1]);</script>
                <% } %>

                    <div id="page-home" class="page active">
                        <div class="stat-banner">
                            <div>
                                <h1 class="header-title" style="margin-bottom: 10px;">Control Panel Server</h1>
                                <p style="color: var(--text-muted); margin: 0; font-size: 15px;">Dashboard utama
                                    manajemen Socket TCP/UDP. Node.js backend sedang berjalan secara real-time.</p>
                            </div>
                            <div style="display: flex; gap: 40px; margin-right: 20px;">
                                <div class="stat-item">
                                    <div class="stat-val" style="color: var(--success);"><i
                                            class="fa-solid fa-check-circle" style="font-size:24px;"></i></div>
                                    <div class="stat-label">Status Node</div>
                                </div>
                                <div class="stat-item">
                                    <div class="stat-val">3001</div>
                                    <div class="stat-label">TCP Port</div>
                                </div>
                                <div class="stat-item">
                                    <div class="stat-val">4000</div>
                                    <div class="stat-label">UDP Port</div>
                                </div>
                            </div>
                        </div>

                        <div class="grid-cards">
                            <!-- Kartu TCP -->
                            <div class="quick-card">
                                <div class="quick-icon"><i class="fa-solid fa-file-export"></i></div>
                                <h3>Transfer File (TCP)</h3>
                                <p>Akses protokol TCP murni untuk mengirim berkas biner ke server tanpa data loss. Ideal
                                    untuk upload dokumen penting.</p>
                                <button class="btn-outline"
                                    onclick="switchPage('upload', document.querySelectorAll('.nav-item')[1])">
                                    Buka Modul TCP <i class="fa-solid fa-arrow-right" style="margin-left:5px;"></i>
                                </button>
                            </div>

                            <!-- Kartu UDP -->
                            <div class="quick-card">
                                <div class="quick-icon"
                                    style="background: rgba(236, 72, 153, 0.1); color: var(--secondary);"><i
                                        class="fa-solid fa-satellite-dish"></i></div>
                                <h3>Live Broadcasting (UDP)</h3>
                                <p>Uji coba protokol UDP datagram untuk menyiarkan potongan video stream secara masif
                                    dan cepat tanpa connection overhead.</p>
                                <button class="btn-outline"
                                    onclick="switchPage('stream', document.querySelectorAll('.nav-item')[2])">
                                    Buka Modul UDP <i class="fa-solid fa-arrow-right" style="margin-left:5px;"></i>
                                </button>
                            </div>


                        </div>

                        <!-- NEW: Live Telemetry Widget -->
                        <div class="card" style="margin-top: 30px; padding: 25px;">
                            <h3 style="margin: 0 0 20px 0; font-size: 16px; font-weight: 600; display: flex; justify-content: space-between; align-items: center;">
                                <span><i class="fa-solid fa-chart-line" style="color:var(--primary); margin-right:8px;"></i> Live Network Telemetry</span>
                                <span style="font-size: 12px; font-weight: 400; color: var(--success);"><i class="fa-solid fa-circle pulse-dot" style="display:inline-block; margin-right:5px;"></i> Sinkronisasi Aktif</span>
                            </h3>
                            
                            <div style="display: flex; gap: 20px;">
                                <div style="flex: 1; background: rgba(0,0,0,0.5); border: 1px solid var(--border-color); border-radius: 12px; padding: 15px;">
                                    <div style="color: var(--text-muted); font-size: 12px; margin-bottom: 10px;">LATENSI UDP (PING)</div>
                                    <div style="font-size: 24px; font-weight: 700; color: #fff;" id="pingValue">14 ms</div>
                                    <div style="height: 4px; background: rgba(255,255,255,0.1); border-radius: 2px; margin-top: 10px; overflow: hidden;">
                                        <div id="pingBar" style="height: 100%; width: 30%; background: var(--success); transition: width 0.5s;"></div>
                                    </div>
                                </div>
                                
                                <div style="flex: 1; background: rgba(0,0,0,0.5); border: 1px solid var(--border-color); border-radius: 12px; padding: 15px;">
                                    <div style="color: var(--text-muted); font-size: 12px; margin-bottom: 10px;">TCP THROUGHPUT</div>
                                    <div style="font-size: 24px; font-weight: 700; color: #fff;" id="throughputValue">1.2 GB/s</div>
                                    <div style="height: 4px; background: rgba(255,255,255,0.1); border-radius: 2px; margin-top: 10px; overflow: hidden;">
                                        <div id="throughputBar" style="height: 100%; width: 75%; background: var(--primary); transition: width 0.5s;"></div>
                                    </div>
                                </div>
                                
                                <div style="flex: 1; background: rgba(0,0,0,0.5); border: 1px solid var(--border-color); border-radius: 12px; padding: 15px;">
                                    <div style="color: var(--text-muted); font-size: 12px; margin-bottom: 10px;">PACKET LOSS</div>
                                    <div style="font-size: 24px; font-weight: 700; color: #fff;" id="packetLossValue">0.00%</div>
                                    <div style="height: 4px; background: rgba(255,255,255,0.1); border-radius: 2px; margin-top: 10px; overflow: hidden;">
                                        <div id="packetLossBar" style="height: 100%; width: 2%; background: var(--warning); transition: width 0.5s;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="page-upload" class="page">
                        <h1 class="header-title">Transmisi Data (TCP)</h1>
                        <p class="header-desc">Kirim paket data dengan jaminan integritas (Port 3001).</p>
                        <div class="card">
                            <% if (typeof uploadStatus !=='undefined' && uploadStatus) { %>
                                <div
                                    style="background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.3); padding: 20px; border-radius: 12px; margin-bottom: 25px; display: flex; align-items: center; gap: 15px;">
                                    <div
                                        style="background: var(--success); color: white; width: 45px; height: 45px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0;">
                                        <i class="fa-solid fa-check"></i>
                                    </div>
                                    <div>
                                        <h4 style="margin: 0 0 5px 0; color: var(--success); font-size: 16px;">Transmisi
                                            TCP Berhasil (Status: 200 OK)</h4>
                                        <p style="margin: 0; color: var(--text-muted); font-size: 14px;">Berkas telah
                                            selesai dikirim melalui socket TCP murni (Port 3001) dan disimpan di server.
                                            Silakan buka tab <strong>UDP Streaming</strong> untuk memutar media
                                            tersebut.</p>
                                    </div>
                                </div>
                                <% } %>

                                    <form action="/upload" method="POST" enctype="multipart/form-data">
                                        <input type="hidden" name="email" value="<%= email %>">
                                        <div class="file-drop-area" id="dropArea">
                                            <i class="fa-solid fa-file-export" id="uploadIcon"></i>
                                            <h3 style="margin:0 0 10px 0; font-weight:600;" id="uploadTitle">Pilih
                                                Berkas Pengiriman</h3>
                                            <p style="color: var(--text-muted); font-size: 14px; margin: 0;"
                                                id="uploadDesc">Berkas akan dialirkan melalui stream socket TCP Backend.
                                            </p>
                                            <input type="file" name="file" class="file-input" required id="fileInput"
                                                onchange="fileSelected()">
                                        </div>
                                        <div style="text-align: right;">
                                            <button type="submit" class="btn-primary" id="btnSubmit">
                                                Inisiasi TCP Socket <i class="fa-solid fa-arrow-right"></i>
                                            </button>
                                        </div>
                                    </form>
                        </div>
                    </div>

                    <div id="page-stream" class="page">
                        <h1 class="header-title">Live Broadcast (UDP)</h1>
                        <p class="header-desc">Menerima aliran data video real-time via datagram sockets.</p>

                        <div class="card" style="padding: 0; overflow: visible;">
                            <div class="live-container" id="liveContainer">
                                <div class="video-wrapper">
                                    <div class="live-overlay">
                                        <div class="live-badge"><i class="fa-solid fa-tower-broadcast"></i> LIVE STREAM
                                        </div>
                                    </div>
                                    <video id="videoPlayer" controls>
                                        <source src="/stream-video" type="video/mp4">
                                    </video>
                                </div>
                            </div>

                            <div
                                style="padding: 20px; display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--border-color); background: var(--panel-bg); border-bottom-left-radius: 20px; border-bottom-right-radius: 20px;">
                                <div style="display: flex; gap: 15px;">
                                    <button class="btn-primary" onclick="startUDP()"
                                        style="background: linear-gradient(135deg, var(--warning), #d97706);">
                                        <i class="fa-solid fa-tower-broadcast"></i> Mulai Broadcast UDP
                                    </button>
                                    <button class="btn-outline" onclick="refreshVideo()"
                                        style="background: rgba(255,255,255,0.05);">
                                        <i class="fa-solid fa-rotate"></i> Muat Video Terbaru
                                    </button>
                                </div>
                                <div style="text-align: right;">
                                    <span
                                        style="color: var(--success); font-size: 13px; font-weight:600; display:block;"><i
                                            class="fa-solid fa-circle" style="font-size:8px;"></i> Port 4000
                                        Aktif</span>
                                </div>
                            </div>
                        </div>

                        <div class="card" style="padding: 25px;">
                            <h3 style="margin: 0 0 15px 0; font-size: 16px; font-weight: 600;">
                                <i class="fa-solid fa-terminal" style="color:var(--primary); margin-right:8px;"></i> UDP
                                Datagram Logs
                            </h3>
                            <div class="udp-logs" id="udpLogs">
                                [SYSTEM] Backend Node.js telah siap. Menunggu inisiasi siaran...
                            </div>
                        </div>
                    </div>
        </div>
    </div>

    <script>
        function switchPage(pageId, navElement) {
            document.querySelectorAll('.page').forEach(page => page.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(item => item.classList.remove('active'));
            document.getElementById('page-' + pageId).classList.add('active');
            navElement.classList.add('active');
        }

        // Live Telemetry Animation (UX enhancement)
        setInterval(() => {
            if(document.getElementById('page-home').classList.contains('active')) {
                const ping = Math.floor(Math.random() * 20) + 10; // 10-30ms
                document.getElementById('pingValue').innerText = ping + " ms";
                document.getElementById('pingBar').style.width = (ping / 50 * 100) + "%";

                const tp = (Math.random() * 1.5 + 0.5).toFixed(2); // 0.5 - 2.0 GB/s
                document.getElementById('throughputValue').innerText = tp + " GB/s";
                document.getElementById('throughputBar').style.width = (tp / 3 * 100) + "%";
                
                const loss = (Math.random() * 0.05).toFixed(2); // 0.00 - 0.05%
                document.getElementById('packetLossValue').innerText = loss + "%";
                document.getElementById('packetLossBar').style.width = (loss * 100) + "%";
            }
        }, 2000);

        // UX File Upload TCP
        function fileSelected() {
            const input = document.getElementById('fileInput');
            if (input.files && input.files[0]) {
                const fileName = input.files[0].name;
                const fileSize = (input.files[0].size / (1024 * 1024)).toFixed(2);
                document.getElementById('uploadTitle').innerText = fileName;
                document.getElementById('uploadDesc').innerText = "Status: Siap ditransmisikan (" + fileSize + " MB)";
                document.getElementById('uploadIcon').className = "fa-solid fa-file-circle-check";
                document.getElementById('uploadIcon').style.color = "var(--success)";
                document.getElementById('dropArea').style.borderColor = "var(--success)";
                document.getElementById('dropArea').style.background = "rgba(16, 185, 129, 0.05)";
                document.getElementById('btnSubmit').innerHTML = "Mulai Alirkan Data (TCP) <i class='fa-solid fa-paper-plane'></i>";
            }
        }

        function refreshVideo() {
            const video = document.getElementById('videoPlayer');
            // Menambahkan timestamp agar browser memuat ulang file terbaru tanpa terhalang cache
            video.src = "/stream-video?t=" + new Date().getTime();
            video.load();
            video.play().catch(e => console.log("Menunggu interaksi pengguna untuk autoplay."));

            const logs = document.getElementById('udpLogs');
            logs.innerHTML += '<br><br>[SYSTEM] Menyinkronkan pemutar dengan file video TCP terbaru dari server...';
            logs.scrollTop = logs.scrollHeight;
        }

        // UDP LOGIC
        let isStreaming = false;
        function startUDP() {
            if (isStreaming) return;
            isStreaming = true;

            document.getElementById('videoPlayer').play();
            const logs = document.getElementById('udpLogs');
            logs.innerHTML += '<br><br>[UDP CLIENT] Menghubungi Port 4000...';

            fetch('/start-udp').then(() => {
                setInterval(() => {
                    fetch('/udp-logs').then(res => res.json()).then(data => {
                        if (data.log) {
                            logs.innerHTML += '<br>' + data.log;
                            logs.scrollTop = logs.scrollHeight;
                        }
                    });
                }, 800);
            });
        }
    </script>
</body>

</html>